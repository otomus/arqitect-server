# Arqitect Configuration
# Copy this file to arqitect.yaml and fill in your values:
#   cp arqitect.yaml.example arqitect.yaml
#
# Or run the interactive wizard:
#   make init

name: Arqitect
environment: server

inference:
  provider: gguf
  models:
    brain: Qwen2.5-Coder-7B.gguf
    nerve: Qwen2.5-Coder-7B.gguf
    coder: Qwen2.5-Coder-7B.gguf
    creative: Qwen2.5-Coder-7B.gguf
    communication: Qwen2.5-Coder-7B.gguf
    vision: moondream2-text-model-f16.gguf
  roles:
    brain:
      provider: null
      model: null
    nerve:
      provider: null
      model: null
    coder:
      provider: null
      model: null
    creative:
      provider: null
      model: null
    communication:
      provider: null
      model: null
  # models_dir: /path/to/models

personality:
  name: ''
  preset: ''
  tone: ''
  traits: []
  communication_style:
    emoji_level: moderate
    formality: casual
    verbosity: concise

senses:
  sight:
    enabled: true
    provider: ''
  hearing:
    enabled: true
    stt: ''
    tts: ''
  touch:
    enabled: true
    environment: server
    filesystem:
      access: sandboxed
      root: ./sandbox
    execution:
      enabled: true
      allowlist: []
  awareness:
    enabled: true
  communication:
    enabled: true

connectors:
  telegram:
    enabled: false
    bot_name: Arqitect
    bot_aliases: []
    whitelisted_users: []
    whitelisted_groups: []
    monitor_groups: []
  whatsapp:
    enabled: false
    bot_name: Arqitect
    bot_aliases: []
    whitelisted_users: []
    whitelisted_groups: []
    monitor_groups: []

embeddings:
  provider: gguf
  model: Qwen2.5-Coder-7B.gguf

storage:
  hot:
    url: redis://localhost:6379
  cold:
    path: arqitect_memory.db
  warm:
    path: episodes.db

ports:
  mcp: 8100
  bridge: 3000

ssl:
  cert: ''
  key: ''

admin:
  name: ''
  email: ''

# ⚠️  NEVER commit real values below — keep them in arqitect.yaml only
secrets:
  jwt_secret: ''          # auto-generated by wizard
  telegram_bot_token: ''  # from @BotFather
  anthropic_api_key: ''
  openai_api_key: ''
  openai_base_url: https://api.openai.com/v1
  groq_api_key: ''
  deepseek_api_key: ''
  mistral_api_key: ''
  openrouter_api_key: ''
  google_ai_api_key: ''
  xai_api_key: ''
  together_api_key: ''
  smtp:
    host: smtp.gmail.com
    port: 587
    user: ''
    password: ''
    from: ''
